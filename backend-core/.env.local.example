# Copy to backend-core/.env.local, fill in the real values, then load with:
#   set -a
#   source backend-core/.env.local
#   set +a
#
# Minimal backend env for local WBR / Amazon Ads work, including the SB probe.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REDIRECT_URI=

BACKEND_ALLOWED_ORIGINS=http://localhost:3000,https://tools.ecomlabs.ca
ENABLE_USAGE_LOGGING=1

# Usually not required for the SB probe itself, but commonly needed for backend startup.
OPENAI_API_KEY=

# Optional / already defaulted in code, shown here for clarity.
APP_VERSION=local
